rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow user to update their own profile completely
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /internships/{internshipId} {
      allow read: if request.auth != null;

      // Allow creation
      allow create: if request.auth != null;

      // Restrict update: do not allow the client to update the 'status' field directly.
      // Any attempt to modify 'status' via client-side sdk updateDoc() will be rejected.
      // (This forces them to use the callable transitionInternshipState function)
      allow update: if request.auth != null
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']));

      allow delete: if request.auth != null && resource.data.studentId == request.auth.uid;

      match /time_logs/{logId} {
        allow create, read: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/internships/$(internshipId)).data.studentId;
        allow read, update: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/internships/$(internshipId)).data.mentorId;
      }
    }

    // Allow public read for snapshots so verification page works without auth
    match /archived_internships/{snapshotId} {
      allow get: if true;
      allow list: if false;
      allow write: if false; // Only backend creates these
    }

    // Default fallback (block writes unless explicitly allowed above)
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
