rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return getUserRole() == 'admin';
    }
    function isCoordinator() {
      return getUserRole() == 'coordinator';
    }

    // Allow user to update their own profile completely, or admins/coordinators to update
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin() || isCoordinator());
    }

    match /organizations/{organizationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (isAdmin() || isCoordinator());
    }

    match /placements/{placementId} {
      // Students can read their own placements, Mentors can read their mentees' placements, Admins/Coordinators can read all
      allow read: if request.auth != null && (
        resource.data.studentId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid ||
        isAdmin() ||
        isCoordinator()
      );

      // Allow creation
      allow create: if request.auth != null;

      // Restrict update: do not allow the client to update the 'status' field directly.
      // Any attempt to modify 'status' via client-side sdk updateDoc() will be rejected.
      // (This forces them to use the callable transitionPlacementState function)
      allow update: if request.auth != null
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']));

      allow delete: if request.auth != null && resource.data.studentId == request.auth.uid;

      match /time_logs/{logId} {
        allow create, read: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/placements/$(placementId)).data.studentId;
        allow read, update: if request.auth != null && request.auth.uid == get(/databases/$(database)/documents/placements/$(placementId)).data.mentorId;
      }
    }

    // Allow public read for snapshots so verification page works without auth
    match /archived_placements/{snapshotId} {
      allow get: if true;
      allow list: if false;
      allow write: if false; // Only backend creates these
    }

    match /commissions/{commissionId} {
      allow read: if request.auth != null && (
        resource.data.studentId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid ||
        isAdmin() ||
        isCoordinator()
      );
      allow write: if request.auth != null && (isAdmin() || isCoordinator());
    }

    // Default fallback (block writes unless explicitly allowed above)
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
