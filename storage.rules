rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdminOrCoordinator() {
      return request.auth != null && request.auth.token.role in ['admin', 'coordinator'];
    }

    match /contracts/{userId}/{fileName} {
      allow read, create: if request.auth != null && (request.auth.uid == userId || isAdminOrCoordinator());
      allow update, delete: if false; // WORM compliance
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdminOrCoordinator());
    }

    match /global_documents/{category}/{dept}/{fileName} {
      allow read: if request.auth != null;
      allow delete: if isAdminOrCoordinator();
      allow create, update: if isAdminOrCoordinator()
        && request.resource.contentType.matches('application/pdf|application/vnd.openxmlformats-officedocument.*|application/msword|application/vnd.ms-excel|text/csv|application/vnd.ms-powerpoint');
    }
    match /certificates/{fileName} {
      allow get: if true; // Public access to certificates so the verify page works
      allow list: if false;
      allow write: if false; // Only backend writes these
    }
    match /decrees/{fileName} {
      allow get: if true; // Public access to decrees so the verify page works
      allow list: if false;
      allow write: if false; // Only backend writes these
    }
  }
}
